{
  "buildCommand": "pnpm run build:vercel:single",
  "outputDirectory": "apps/web/build/client",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://flyersplane.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://flyersplane.onrender.com/auth/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://flyersplane.onrender.com/static/:path*"
    },
    {
      "source": "/god-mode",
      "destination": "/god-mode/index.html"
    },
    {
      "source": "/god-mode/:path*",
      "destination": "/god-mode/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
